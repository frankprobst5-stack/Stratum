{
    "name": "stratum/cms",
    "description": "Stratum CMS — a modular, community-first portal platform for clubs and associations.",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "autoload": {
        "psr-4": {
            "Stratum\\Core\\": "core/services/",
            "Stratum\\Admin\\": "core/admin/controllers/",
            "Stratum\\Api\\": "core/api/controllers/"
        },
        "files": [
            "core/services/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "scripts": {
        "test": "phpunit"
    }
}
