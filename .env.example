APP_ENV=production
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stratum
DB_USERNAME=stratum
DB_PASSWORD=
DB_PREFIX=strat_
DB_CHARSET=utf8mb4

# Full-page cache for guest (logged-out) GET requests — off by default,
# opt in once real traffic actually makes it worth the tradeoff (see
# docs/roadmap.md's Cache Manager entry for what it does and doesn't cover).
PAGE_CACHE_ENABLED=false
PAGE_CACHE_TTL_SECONDS=300

# REST API rate limiting (Stage 10) — on by default, since the API is
# public-facing. Per-identifier (API token, or IP for guest reads),
# fixed one-minute window. See core/services/ApiRateLimiter.php.
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=60
